FROM golang:1.26-alpine

RUN apk add --no-cache git && \
    go install github.com/air-verse/air@latest && \
    go install -tags 'postgres' github.com/golang-migrate/migrate/v4/cmd/migrate@v4.18.1

WORKDIR /workspace

COPY go.mod go.sum ./
COPY pkg/ ./pkg/
COPY services/notification/ ./services/notification/

RUN printf 'go 1.26.1\n\nuse (\n\t.\n\t./services/notification\n)\n' > go.work
RUN go work sync && cd services/notification && go mod download

WORKDIR /workspace/services/notification

ENTRYPOINT ["sh", "scripts/entrypoint.dev.sh"]
